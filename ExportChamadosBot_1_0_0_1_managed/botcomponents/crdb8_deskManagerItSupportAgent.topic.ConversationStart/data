kind: AdaptiveDialog
beginDialog:
  kind: OnConversationStart
  id: main
  actions:
    - kind: ClearAllVariables
      id: pXQDRu

    - kind: InvokeFlowAction
      id: invokeFlowAction_6szwPO
      input: {}
      output:
        binding:
          token: Topic.Token

      flowId: 8575b34a-e7e7-f011-8544-7c1e526a9a9f

    - kind: SendActivity
      id: sendMessage_M0LuhV
      displayName: Saudação
      activity:
        text:
          - |-
            👋 Olá! Eu sou o **{System.Bot.Name}**, 
            seu assistente da TI Emccamp.   


            🚀 Estou aqui para ajudar você a abrir e acompanhar chamados de forma rápida e eficiente.
        speak:
          - Hello and thank you for calling {System.Bot.Name}. Please note that some responses are generated by AI and may require verification for accuracy. How may I help you today?

    - kind: InvokeFlowAction
      id: invokeFlowAction_SMZMDi
      input:
        binding:
          email: =System.User.Email

      output:
        binding:
          codigo_solicitante: Global.Codigo_Solicitante
          email_solicitante: Global.Email_Solicitante
          nome_completo: Global.Nome_Completo

      flowId: 9d171135-e2e7-f011-8544-7c1e526a9a9f

    - kind: ConditionGroup
      id: conditionGroup_kUKYqB
      conditions:
        - id: conditionItem_hu66a6
          condition: =Global.Codigo_Solicitante = 0
          actions:
            - kind: InvokeFlowAction
              id: invokeFlowAction_cqqyOM
              input:
                binding:
                  email: =System.User.Email
                  text: =Topic.Token
                  text_1: =System.User.FirstName
                  text_2: =System.User.LastName

              output:
                binding:
                  codsolicitante: Global.Codigo_Solicitante

              flowId: ee28e38d-b89c-8af0-8552-f01fe55c56e6

    - kind: SendActivity
      id: sendActivity_364mwt
      displayName: Apresentação
      activity: |
        🔎 Localizei seu cadastro aqui!


        Estou falando com **{System.User.FirstName},** Correto?

    - kind: BeginDialog
      id: slnu6U
      dialog: crdb8_deskManagerItSupportAgent.topic.MenuPrincipal