                binding:
                  SolicitacaoInfra: Topic.SolicitacaoInfra
                  SolicitacaoSistemas: Topic.SolicitacaoSistemas

        - id: conditionItem_Azl45H
          condition: =Topic.Var1 = 'crdb8_deskManagerItSupportAgent.topic.MenuPrincipal.main.question_4GiwfR'.'Consultar um chamado'
          actions:
            - kind: BeginDialog
              id: a2cq13
              dialog: crdb8_deskManagerItSupportAgent.topic.Consultarumchamado

        - id: conditionItem_88WWpD
          condition: =Topic.Var1 = 'crdb8_deskManagerItSupportAgent.topic.MenuPrincipal.main.question_4GiwfR'.'Finalizar atendimento'
