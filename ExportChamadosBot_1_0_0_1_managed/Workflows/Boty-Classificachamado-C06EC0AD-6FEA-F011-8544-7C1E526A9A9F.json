                  "type": "SetVariable",
                  "inputs": {
                    "name": "Chave Categoria",
                    "value": "@first(body('OrganizaJsonCategorias')?['root'])?['Chave']"
                  }
                },
                "Assunto_1": {
                  "type": "SetVariable",
                  "inputs": {
                    "name": "Assunto Categoria",
                    "value": "@first(body('OrganizaJsonCategorias')?['root'])?['Assunto']"
