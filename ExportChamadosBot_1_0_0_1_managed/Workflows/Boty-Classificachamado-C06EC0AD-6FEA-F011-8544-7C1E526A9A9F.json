        "Tentativa": {
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "Tentativa",
                "type": "integer",
                "value": 0
              }
            ]
          },
          "runAfter": {}
        },
        "Switch_1": {
          "type": "Switch",
          "expression": "@variables('Status')",
          "default": {
            "actions": {}
