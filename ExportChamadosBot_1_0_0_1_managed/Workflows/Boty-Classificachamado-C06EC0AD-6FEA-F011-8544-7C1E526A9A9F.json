          "type": "Http",
          "inputs": {
            "uri": "https://api.desk.ms/AutoCategorias/lista",
            "method": "POST",
            "headers": {
              "Authorization": "@{triggerBody()?['text']}"
            },
            "body": {
              "Pesquisa": "@triggerBody()?['text_1']",
              "Ativo": "S",
              "Colunas": {
                "Chave": "on",
                "Assunto": "on"
              },
              "Ordem": [
                {
                  "Coluna": "Assunto",
                  "Direcao": "true"
                }
              ]
            }
          },
          "runAfter": {
            "Resposta_final": [
              "Succeeded"
            ]
          },
          "runtimeConfiguration": {
            "contentTransfer": {
              "transferMode": "Chunked"
            }
          }
        },
        "Token": {
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "Token",
                "type": "string",
                "value": "@triggerBody()?['text']"
              }
