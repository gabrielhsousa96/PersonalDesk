          "type": "ParseJson",
          "inputs": {
            "content": "@body('Busca_lista_de_categorias')",
            "schema": {
              "type": "object",
              "properties": {
                "root": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "Chave": {
                        "type": "integer"
                      },
                      "Assunto": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "Chave",
                      "Assunto"
                    ]
                  }
                },
                "total": {
                  "type": "string"
                }
              }
            }
          },
          "runAfter": {
            "Busca_lista_de_categorias": [
              "Succeeded"
            ]
          }
        },
        "Switch": {
          "type": "Switch",
          "expression": "@length(body('OrganizaJsonCategorias')?['root'])",
          "default": {
            "actions": {
              "Variavel_Status": {
                "type": "SetVariable",
                "inputs": {
                  "name": "Status",
                  "value": "Multiplas"
                },
                "runAfter": {
                  "For_each": [
                    "SUCCEEDED"
                  ]
                }
              },
              "For_each": {
                "type": "Foreach",
                "foreach": "@outputs('OrganizaJsonCategorias')?['body']?['root']",
                "actions": {
                  "Append_to_array_variable": {
                    "type": "AppendToArrayVariable",
                    "inputs": {
                      "name": "Resposta final",
                      "value": "@items('For_each')?['Assunto']"
                    }
                  }
                }
              }
            }
